CORS_ALLOWED=http://localhost:*             # Toda url se separa con comas y sin espacios en blanco
JPA_SHOW_SQL=false                           # Activar solo para depuracion local
JPA_FORMAT_SQL=false                         # Activar solo para depuracion local
